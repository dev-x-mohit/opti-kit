{
  "name": "opti-kit-monorepo",
  "private": true,
  "description": "The Zero-Dependency, Ultra-Lightweight Utility Engine for Modern JavaScript & TypeScript.",
  "homepage": "https://opti-kit-showcase.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev-x-mohit/opti-kit.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:package": "npm run build -w packages/opti-kit",
    "build:showcase": "npm run build -w apps/showcase",
    "test:package": "npm run test -w packages/opti-kit",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "tailwindcss": "^4.3.3"
  }
}
