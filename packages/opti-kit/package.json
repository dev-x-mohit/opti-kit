{
  "name": "@dev_x_mohit/opti-kit",
  "version": "1.0.7",

  "description": "OptiKit is a zero-dependency, ultra-lightweight, and fully tree-shakeable JavaScript/TypeScript utility monorepo library. It ships 25 hand-optimized isomorphic modules — strings, arrays, objects, math, numbers, async, crypto, validation, dates, color converters, storage, event emitter, DOM helpers, URL parsing, regex, tree traversal, statistics, geometry, units, encoding, cache, functional programming, collections, random, and types. Every function is side-effect free, individually importable, and ships with full TypeScript declarations, CJS/ESM dual output, 328+ utilities, and 300+ unit tests.",

  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "utilities",
    "utils",
    "typescript",
    "tree-shakeable",
    "lightweight",
    "zero-dependencies",
    "esm",
    "cjs",
    "isomorphic",
    "event-emitter",
    "safe-storage",
    "uuid",
    "sha256",
    "generate-token",
    "color-converter",
    "relative-time",
    "string-utils",
    "array-utils",
    "math-utils",
    "object-utils",
    "number-format",
    "validation",
    "debounce",
    "throttle",
    "deep-clone",
    "deep-merge",
    "flatten-object",
    "interpolate",
    "slugify",
    "truncate",
    "titlecase",
    "ordinal",
    "compact-number",
    "median",
    "standard-deviation",
    "lodash-alternative",
    "ramda-alternative",
    "underscore-alternative",
    "javascript-utilities",
    "js-utils",
    "ts-utils",
    "helper-functions",
    "functional-programming",
    "curry",
    "pipe",
    "compose",
    "memoize",
    "retry",
    "async-pool",
    "lru-cache",
